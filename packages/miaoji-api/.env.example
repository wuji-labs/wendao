# Wendao backend — example env (copy to .env)

# Postgres connection string
DATABASE_URL=postgres://miaoji:miaoji@localhost:5432/miaoji
DB_POOL_MAX=10

# HTTP server
PORT=3100
HOST=0.0.0.0
# Comma-separated allowed origins for non-LAN requests (LAN ranges are always allowed).
# Set this to your public web origin when exposing the API behind a reverse proxy.
CORS_ORIGIN=http://localhost:3101

# Local storage root for media + transcoded artifacts
MIAOJI_STORAGE_DIR=./.storage

# Optional archive dir (empty = disabled). When set, a READY minute's recording + transcript
# are copied to <dir>/<YYYY-MM>/<title-token>/. Use any local dir or mounted NAS/SMB share,
# e.g. /mnt/archive or D:\archive\wendao
MIAOJI_ARCHIVE_DIR=

# ffmpeg / ffprobe (just needs to be on PATH)
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Python ASR / diarization microservice
MIAOJI_ASR_URL=http://127.0.0.1:9400

# Ollama (OpenAI-compatible) for AI minutes / translation / Q&A
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama
MIAOJI_LLM_MODEL=qwen3:30b-a3b

# Pipeline worker poll interval (ms)
MIAOJI_WORKER_POLL_MS=3000
