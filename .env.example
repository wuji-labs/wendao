# Wendao — root environment (used by docker-compose and as a reference).
# Copy to .env. Per-package examples also exist (packages/miaoji-api/.env.example).

# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=miaoji
POSTGRES_PASSWORD=miaoji
POSTGRES_DB=miaoji
# Connection string used by the API/worker (host port for local dev).
DATABASE_URL=postgres://miaoji:miaoji@localhost:5432/miaoji

# ── API (packages/miaoji-api) ───────────────────────────────────────────────
PORT=3100
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3101
MIAOJI_STORAGE_DIR=./.storage
# Optional archive dir (empty = disabled).
MIAOJI_ARCHIVE_DIR=
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
MIAOJI_WORKER_POLL_MS=3000

# ── Web (apps/miaoji) ───────────────────────────────────────────────────────
# Where the browser reaches the API for direct (large-file) uploads.
NEXT_PUBLIC_MIAOJI_API_BASE=http://127.0.0.1:3100
# Same-origin rewrite target the Next server proxies to.
MIAOJI_API_URL=http://127.0.0.1:3100
# Comma-separated LAN hosts/IPs allowed as Next dev origins (e.g. 192.168.1.50). Optional.
NEXT_PUBLIC_DEV_ORIGINS=

# ── ASR microservice (apps/miaoji-asr) ──────────────────────────────────────
MIAOJI_ASR_URL=http://127.0.0.1:9400
MIAOJI_ASR_HOST=0.0.0.0
MIAOJI_ASR_PORT=9400
ASR_DEVICE=auto
WHISPER_MODEL=large-v3
# Hugging Face token — required only for pyannote speaker diarization
# (accept the model terms at https://hf.co/pyannote/speaker-diarization-3.1).
HF_TOKEN=

# ── LLM (Ollama, OpenAI-compatible) for AI minutes / translation / Q&A ──────
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama
MIAOJI_LLM_MODEL=qwen3:30b-a3b
